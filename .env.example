# --- OpenAI ---
# Required for live LLM and image generation.
# If OPENAI_API_KEY is empty/missing, the app falls back to MOCK MODE
# (deterministic stub agents). All tests run in mock mode by default.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2

# --- Feature flags ---
USE_RAG=true
USE_LLM_CACHE=true
ENABLE_IMAGE_GENERATION=true

# --- Multi-agent discussion ---
MAX_AGENT_DISCUSSION_ROUNDS=3
MAX_RETRIEVED_DOCS=5

# --- Token budget ---
MAX_AGENT_INPUT_CHARS=6000
MAX_EVIDENCE_CHARS=2500

# --- Storage ---
SQLITE_PATH=data/scenarios.sqlite
RAG_CHUNKS_PATH=data/rag_chunks.json
GENERATED_IMAGES_DIR=data/generated_images
